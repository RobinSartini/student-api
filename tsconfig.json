{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "outDir": "./dist",
    "rootDir": "./",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*", "server.ts", "tests/**/*"],
  "exclude": ["node_modules", "dist"]
}
